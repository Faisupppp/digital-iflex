<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>Dashboard - Digital iflex Admin</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #0a0a0a;
            color: #fff;
            min-height: 100vh
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 240px;
            height: 100vh;
            background: #111;
            border-right: 1px solid #222;
            padding: 20px 0;
            z-index: 100
        }

        .sidebar .logo {
            padding: 0 20px 25px;
            font-size: 22px;
            font-weight: 800;
            border-bottom: 1px solid #222
        }

        .logo span {
            color: #F44336
        }

        .sidebar nav {
            padding: 15px 10px
        }

        .sidebar nav a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: #aaa;
            font-size: 14px;
            font-weight: 500;
            border-radius: 10px;
            margin-bottom: 4px;
            transition: .3s;
            text-decoration: none
        }

        .sidebar nav a:hover,
        .sidebar nav a.active {
            background: rgba(244, 67, 54, .1);
            color: #F44336
        }

        .sidebar nav a i {
            width: 20px;
            text-align: center;
            font-size: 16px
        }

        .sidebar .logout {
            position: absolute;
            bottom: 20px;
            left: 10px;
            right: 10px
        }

        .sidebar .logout a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: #aaa;
            font-size: 14px;
            border-radius: 10px;
            transition: .3s;
            text-decoration: none
        }

        .sidebar .logout a:hover {
            background: rgba(244, 67, 54, .1);
            color: #F44336
        }

        .main {
            margin-left: 240px;
            padding: 30px
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px
        }

        .topbar h2 {
            font-size: 24px
        }

        .topbar .admin-tag {
            background: #1c1c1c;
            border: 1px solid #333;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 13px;
            color: #aaa
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px
        }

        .stat-card {
            background: #1c1c1c;
            border: 1px solid #222;
            border-radius: 12px;
            padding: 25px;
            transition: .3s
        }

        .stat-card:hover {
            border-color: #F44336;
            transform: translateY(-2px)
        }

        .stat-card .stat-icon {
            width: 45px;
            height: 45px;
            background: rgba(244, 67, 54, .1);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #F44336;
            margin-bottom: 15px
        }

        .stat-card .stat-num {
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 4px
        }

        .stat-card .stat-label {
            color: #aaa;
            font-size: 13px
        }

        .card {
            background: #1c1c1c;
            border: 1px solid #222;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px
        }

        .card h3 {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px
        }

        .card h3 i {
            color: #F44336
        }

        table {
            width: 100%;
            border-collapse: collapse
        }

        table th {
            text-align: left;
            padding: 12px 15px;
            color: #aaa;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid #222
        }

        table td {
            padding: 12px 15px;
            font-size: 14px;
            border-bottom: 1px solid rgba(255, 255, 255, .03)
        }

        table tr:hover td {
            background: rgba(255, 255, 255, .02)
        }

        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600
        }

        .badge-new {
            background: rgba(244, 67, 54, .15);
            color: #F44336
        }

        .badge-read {
            background: rgba(76, 175, 80, .15);
            color: #4CAF50
        }

        .chart-bar {
            display: flex;
            align-items: flex-end;
            gap: 6px;
            height: 120px;
            margin-top: 10px
        }

        .chart-col {
            background: linear-gradient(to top, #F44336, #ff7043);
            border-radius: 4px 4px 0 0;
            min-width: 30px;
            flex: 1;
            transition: .3s;
            position: relative;
            cursor: pointer
        }

        .chart-col:hover {
            opacity: .8
        }

        .chart-col .tooltip {
            position: absolute;
            top: -25px;
            left: 50%;
            transform: translateX(-50%);
            background: #333;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 11px;
            white-space: nowrap;
            opacity: 0;
            transition: .2s
        }

        .chart-col:hover .tooltip {
            opacity: 1
        }

        .chart-labels {
            display: flex;
            gap: 6px;
            margin-top: 8px
        }

        .chart-labels span {
            flex: 1;
            text-align: center;
            font-size: 10px;
            color: #666;
            min-width: 30px
        }

        @media(max-width:768px) {
            .sidebar {
                width: 60px
            }

            .sidebar .logo,
            .sidebar nav a span,
            .sidebar .logout a span {
                display: none
            }

            .main {
                margin-left: 60px;
                padding: 15px
            }

            .stats-grid {
                grid-template-columns: 1fr 1fr
            }
        }
    </style>
</head>

<body>
    <div class="sidebar">
        <div class="logo">Digital <span>iflex</span></div>
        <nav>
            <a href="/admin/dashboard" class="active"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
            <a href="/admin/contacts"><i class="fas fa-envelope"></i><span>Contacts</span></a>
            <a href="/admin/blog"><i class="fas fa-blog"></i><span>Blog Posts</span></a>
            <a href="/admin/analytics"><i class="fas fa-chart-line"></i><span>Analytics</span></a>
            <a href="/" target="_blank"><i class="fas fa-globe"></i><span>View Site</span></a>
        </nav>
        <div class="logout">
            <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
        </div>
    </div>
    <div class="main">
        <div class="topbar">
            <h2>Dashboard</h2>
            <div class="admin-tag"><i class="fas fa-user"></i>
                <%= admin.username %>
            </div>
        </div>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-eye"></i></div>
                <div class="stat-num">
                    <%= stats.totalViews %>
                </div>
                <div class="stat-label">Total Page Views</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
                <div class="stat-num">
                    <%= stats.todayViews %>
                </div>
                <div class="stat-label">Views Today</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-users"></i></div>
                <div class="stat-num">
                    <%= stats.uniqueVisitors %>
                </div>
                <div class="stat-label">Unique Visitors</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-envelope"></i></div>
                <div class="stat-num">
                    <%= stats.totalContacts %>
                </div>
                <div class="stat-label">Contact Submissions</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-envelope-open"></i></div>
                <div class="stat-num">
                    <%= stats.unreadContacts %>
                </div>
                <div class="stat-label">Unread Messages</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fab fa-whatsapp"></i></div>
                <div class="stat-num">
                    <%= stats.totalWhatsapp %>
                </div>
                <div class="stat-label">WhatsApp Clicks</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-blog"></i></div>
                <div class="stat-num">
                    <%= stats.totalPosts %>
                </div>
                <div class="stat-label">Blog Posts</div>
            </div>
        </div>

        <div class="card">
            <h3><i class="fas fa-chart-bar"></i> Page Views (Last 7 Days)</h3>
            <% if (dailyViews.length> 0) { %>
                <% const maxViews=Math.max(...dailyViews.map(d=> d.views), 1); %>
                    <div class="chart-bar">
                        <% dailyViews.forEach(d=> { %>
                            <div class="chart-col" style="height:<%= Math.max((d.views / maxViews) * 100, 5) %>%">
                                <div class="tooltip">
                                    <%= d.views %> views
                                </div>
                            </div>
                            <% }); %>
                    </div>
                    <div class="chart-labels">
                        <% dailyViews.forEach(d=> { %>
                            <span>
                                <%= d.date.slice(5) %>
                            </span>
                            <% }); %>
                    </div>
                    <% } else { %>
                        <p style="color:#666;font-size:14px">No data yet. Views will appear here once visitors start
                            browsing.</p>
                        <% } %>
        </div>

        <div class="card">
            <h3><i class="fas fa-envelope"></i> Recent Contact Submissions</h3>
            <% if (recentContacts.length> 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Service</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentContacts.forEach(c=> { %>
                            <tr>
                                <td><strong>
                                        <%= c.name %>
                                    </strong></td>
                                <td style="color:#aaa">
                                    <%= c.email %>
                                </td>
                                <td>
                                    <%= c.service || '—' %>
                                </td>
                                <td style="color:#666">
                                    <%= new Date(c.created_at).toLocaleDateString() %>
                                </td>
                                <td><span class="badge <%= c.is_read ? 'badge-read' : 'badge-new' %>">
                                        <%= c.is_read ? 'Read' : 'New' %>
                                    </span></td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
                <% } else { %>
                    <p style="color:#666;font-size:14px">No contact submissions yet.</p>
                    <% } %>
        </div>
    </div>
</body>

</html>