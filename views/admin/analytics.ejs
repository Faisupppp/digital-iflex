<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>Analytics - Digital iflex Admin</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #0a0a0a;
            color: #fff;
            min-height: 100vh
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 240px;
            height: 100vh;
            background: #111;
            border-right: 1px solid #222;
            padding: 20px 0;
            z-index: 100
        }

        .sidebar .logo {
            padding: 0 20px 25px;
            font-size: 22px;
            font-weight: 800;
            border-bottom: 1px solid #222
        }

        .logo span {
            color: #F44336
        }

        .sidebar nav {
            padding: 15px 10px
        }

        .sidebar nav a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: #aaa;
            font-size: 14px;
            font-weight: 500;
            border-radius: 10px;
            margin-bottom: 4px;
            transition: .3s;
            text-decoration: none
        }

        .sidebar nav a:hover,
        .sidebar nav a.active {
            background: rgba(244, 67, 54, .1);
            color: #F44336
        }

        .sidebar nav a i {
            width: 20px;
            text-align: center;
            font-size: 16px
        }

        .sidebar .logout {
            position: absolute;
            bottom: 20px;
            left: 10px;
            right: 10px
        }

        .sidebar .logout a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: #aaa;
            font-size: 14px;
            border-radius: 10px;
            transition: .3s;
            text-decoration: none
        }

        .sidebar .logout a:hover {
            background: rgba(244, 67, 54, .1);
            color: #F44336
        }

        .main {
            margin-left: 240px;
            padding: 30px
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px
        }

        .topbar h2 {
            font-size: 24px
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px
        }

        .stat-card {
            background: #1c1c1c;
            border: 1px solid #222;
            border-radius: 12px;
            padding: 25px;
            text-align: center
        }

        .stat-card .stat-num {
            font-size: 36px;
            font-weight: 800;
            color: #F44336;
            margin-bottom: 4px
        }

        .stat-card .stat-label {
            color: #aaa;
            font-size: 13px
        }

        .card {
            background: #1c1c1c;
            border: 1px solid #222;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px
        }

        .card h3 {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px
        }

        .card h3 i {
            color: #F44336
        }

        .chart-bar {
            display: flex;
            align-items: flex-end;
            gap: 4px;
            height: 160px;
            margin-top: 10px
        }

        .chart-col {
            background: linear-gradient(to top, #F44336, #ff7043);
            border-radius: 4px 4px 0 0;
            min-width: 20px;
            flex: 1;
            transition: .3s;
            position: relative;
            cursor: pointer
        }

        .chart-col:hover {
            opacity: .8
        }

        .chart-col .tooltip {
            position: absolute;
            top: -30px;
            left: 50%;
            transform: translateX(-50%);
            background: #333;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 11px;
            white-space: nowrap;
            opacity: 0;
            transition: .2s;
            z-index: 1
        }

        .chart-col:hover .tooltip {
            opacity: 1
        }

        .chart-col.wa {
            background: linear-gradient(to top, #25D366, #128C7E)
        }

        .chart-labels {
            display: flex;
            gap: 4px;
            margin-top: 8px
        }

        .chart-labels span {
            flex: 1;
            text-align: center;
            font-size: 10px;
            color: #666;
            min-width: 20px
        }

        .two-col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px
        }

        table {
            width: 100%;
            border-collapse: collapse
        }

        table th {
            text-align: left;
            padding: 10px 12px;
            color: #aaa;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid #222
        }

        table td {
            padding: 10px 12px;
            font-size: 13px;
            border-bottom: 1px solid rgba(255, 255, 255, .03)
        }

        table tr:hover td {
            background: rgba(255, 255, 255, .02)
        }

        .progress-bar {
            background: #222;
            border-radius: 4px;
            height: 6px;
            margin-top: 4px
        }

        .progress-fill {
            background: #F44336;
            border-radius: 4px;
            height: 100%;
            transition: .3s
        }

        @media(max-width:768px) {
            .sidebar {
                width: 60px
            }

            .sidebar .logo,
            .sidebar nav a span,
            .sidebar .logout a span {
                display: none
            }

            .main {
                margin-left: 60px;
                padding: 15px
            }

            .stats-grid {
                grid-template-columns: 1fr
            }

            .two-col {
                grid-template-columns: 1fr
            }
        }
    </style>
</head>

<body>
    <div class="sidebar">
        <div class="logo">Digital <span>iflex</span></div>
        <nav>
            <a href="/admin/dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
            <a href="/admin/contacts"><i class="fas fa-envelope"></i><span>Contacts</span></a>
            <a href="/admin/blog"><i class="fas fa-blog"></i><span>Blog Posts</span></a>
            <a href="/admin/analytics" class="active"><i class="fas fa-chart-line"></i><span>Analytics</span></a>
            <a href="/" target="_blank"><i class="fas fa-globe"></i><span>View Site</span></a>
        </nav>
        <div class="logout"><a href="/admin/logout"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a></div>
    </div>
    <div class="main">
        <div class="topbar">
            <h2><i class="fas fa-chart-line" style="color:#F44336;margin-right:10px"></i>Analytics</h2>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-num">
                    <%= totalViews %>
                </div>
                <div class="stat-label">Total Page Views</div>
            </div>
            <div class="stat-card">
                <div class="stat-num">
                    <%= uniqueVisitors %>
                </div>
                <div class="stat-label">Unique Visitors</div>
            </div>
            <div class="stat-card">
                <div class="stat-num">
                    <%= totalWhatsapp %>
                </div>
                <div class="stat-label">WhatsApp Clicks</div>
            </div>
        </div>

        <div class="card">
            <h3><i class="fas fa-chart-area"></i> Page Views (Last 30 Days)</h3>
            <% if (dailyViews.length> 0) { %>
                <% const maxV=Math.max(...dailyViews.map(d=> d.views), 1); %>
                    <div class="chart-bar">
                        <% dailyViews.forEach(d=> { %>
                            <div class="chart-col" style="height:<%= Math.max((d.views / maxV) * 100, 3) %>%">
                                <div class="tooltip">
                                    <%= d.date.slice(5) %>: <%= d.views %> views / <%= d.unique_visitors %> unique
                                </div>
                            </div>
                            <% }); %>
                    </div>
                    <div class="chart-labels">
                        <% dailyViews.forEach((d,i)=> { %><span>
                                <%= i % 3===0 ? d.date.slice(5) : '' %>
                            </span>
                            <% }); %>
                    </div>
                    <% } else { %>
                        <p style="color:#666">No data yet</p>
                        <% } %>
        </div>

        <% if (whatsappClicks.length> 0) { %>
            <div class="card">
                <h3><i class="fab fa-whatsapp"></i> WhatsApp Clicks (Last 30 Days)</h3>
                <% const maxW=Math.max(...whatsappClicks.map(d=> d.clicks), 1); %>
                    <div class="chart-bar">
                        <% whatsappClicks.forEach(d=> { %>
                            <div class="chart-col wa" style="height:<%= Math.max((d.clicks / maxW) * 100, 5) %>%">
                                <div class="tooltip">
                                    <%= d.date.slice(5) %>: <%= d.clicks %> clicks
                                </div>
                            </div>
                            <% }); %>
                    </div>
            </div>
            <% } %>

                <div class="two-col">
                    <div class="card">
                        <h3><i class="fas fa-file"></i> Top Pages</h3>
                        <% if (topPages.length> 0) { %>
                            <% const maxP=topPages[0].views; %>
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Page</th>
                                            <th>Views</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% topPages.forEach(p=> { %>
                                            <tr>
                                                <td>
                                                    <%= p.page %>
                                                </td>
                                                <td>
                                                    <%= p.views %>
                                                </td>
                                                <td style="width:100px">
                                                    <div class="progress-bar">
                                                        <div class="progress-fill"
                                                            style="width:<%= (p.views/maxP)*100 %>%"></div>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }); %>
                                    </tbody>
                                </table>
                                <% } else { %>
                                    <p style="color:#666">No data yet</p>
                                    <% } %>
                    </div>

                    <div class="card">
                        <h3><i class="fas fa-link"></i> Top Referrers</h3>
                        <% if (topReferrers.length> 0) { %>
                            <table>
                                <thead>
                                    <tr>
                                        <th>Source</th>
                                        <th>Visits</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% topReferrers.forEach(r=> { %>
                                        <tr>
                                            <td
                                                style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                                <%= r.referrer %>
                                            </td>
                                            <td>
                                                <%= r.count %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                            <% } else { %>
                                <p style="color:#666">No referrer data yet</p>
                                <% } %>
                    </div>
                </div>
    </div>
</body>

</html>