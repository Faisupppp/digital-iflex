<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>Contacts - Digital iflex Admin</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #0a0a0a;
            color: #fff;
            min-height: 100vh
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 240px;
            height: 100vh;
            background: #111;
            border-right: 1px solid #222;
            padding: 20px 0;
            z-index: 100
        }

        .sidebar .logo {
            padding: 0 20px 25px;
            font-size: 22px;
            font-weight: 800;
            border-bottom: 1px solid #222
        }

        .logo span {
            color: #F44336
        }

        .sidebar nav {
            padding: 15px 10px
        }

        .sidebar nav a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: #aaa;
            font-size: 14px;
            font-weight: 500;
            border-radius: 10px;
            margin-bottom: 4px;
            transition: .3s;
            text-decoration: none
        }

        .sidebar nav a:hover,
        .sidebar nav a.active {
            background: rgba(244, 67, 54, .1);
            color: #F44336
        }

        .sidebar nav a i {
            width: 20px;
            text-align: center;
            font-size: 16px
        }

        .sidebar .logout {
            position: absolute;
            bottom: 20px;
            left: 10px;
            right: 10px
        }

        .sidebar .logout a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            color: #aaa;
            font-size: 14px;
            border-radius: 10px;
            transition: .3s;
            text-decoration: none
        }

        .sidebar .logout a:hover {
            background: rgba(244, 67, 54, .1);
            color: #F44336
        }

        .main {
            margin-left: 240px;
            padding: 30px
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px
        }

        .topbar h2 {
            font-size: 24px
        }

        .card {
            background: #1c1c1c;
            border: 1px solid #222;
            border-radius: 12px;
            padding: 25px;
            margin-bottom: 20px
        }

        table {
            width: 100%;
            border-collapse: collapse
        }

        table th {
            text-align: left;
            padding: 12px 15px;
            color: #aaa;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid #222
        }

        table td {
            padding: 12px 15px;
            font-size: 14px;
            border-bottom: 1px solid rgba(255, 255, 255, .03)
        }

        table tr:hover td {
            background: rgba(255, 255, 255, .02)
        }

        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600
        }

        .badge-new {
            background: rgba(244, 67, 54, .15);
            color: #F44336
        }

        .badge-read {
            background: rgba(76, 175, 80, .15);
            color: #4CAF50
        }

        .btn-sm {
            padding: 5px 12px;
            border-radius: 6px;
            border: 1px solid #333;
            background: transparent;
            color: #aaa;
            font-size: 12px;
            cursor: pointer;
            transition: .3s;
            text-decoration: none;
            display: inline-block
        }

        .btn-sm:hover {
            border-color: #F44336;
            color: #F44336
        }

        .btn-danger {
            border-color: #F44336;
            color: #F44336
        }

        .btn-danger:hover {
            background: #F44336;
            color: #fff
        }

        .msg-preview {
            max-width: 250px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            color: #aaa
        }

        @media(max-width:768px) {
            .sidebar {
                width: 60px
            }

            .sidebar .logo,
            .sidebar nav a span,
            .sidebar .logout a span {
                display: none
            }

            .main {
                margin-left: 60px;
                padding: 15px
            }
        }
    </style>
</head>

<body>
    <div class="sidebar">
        <div class="logo">Digital <span>iflex</span></div>
        <nav>
            <a href="/admin/dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
            <a href="/admin/contacts" class="active"><i class="fas fa-envelope"></i><span>Contacts</span></a>
            <a href="/admin/blog"><i class="fas fa-blog"></i><span>Blog Posts</span></a>
            <a href="/admin/analytics"><i class="fas fa-chart-line"></i><span>Analytics</span></a>
            <a href="/" target="_blank"><i class="fas fa-globe"></i><span>View Site</span></a>
        </nav>
        <div class="logout"><a href="/admin/logout"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a></div>
    </div>
    <div class="main">
        <div class="topbar">
            <h2><i class="fas fa-envelope" style="color:#F44336;margin-right:10px"></i>Contact Submissions (<%=
                    contacts.length %>)</h2>
        </div>
        <div class="card">
            <% if (contacts.length> 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Service</th>
                            <th>Message</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% contacts.forEach(c=> { %>
                            <tr>
                                <td><strong>
                                        <%= c.name %>
                                    </strong></td>
                                <td style="color:#aaa">
                                    <%= c.email %>
                                </td>
                                <td style="color:#aaa">
                                    <%= c.country_code %>
                                        <%= c.phone %>
                                </td>
                                <td>
                                    <%= c.service || '—' %>
                                </td>
                                <td class="msg-preview">
                                    <%= c.message || '—' %>
                                </td>
                                <td style="color:#666;font-size:12px">
                                    <%= new Date(c.created_at).toLocaleDateString() %><br>
                                        <%= new Date(c.created_at).toLocaleTimeString() %>
                                </td>
                                <td><span class="badge <%= c.is_read ? 'badge-read' : 'badge-new' %>">
                                        <%= c.is_read ? 'Read' : 'New' %>
                                    </span></td>
                                <td>
                                    <% if (!c.is_read) { %>
                                        <form method="POST" action="/admin/contacts/<%= c.id %>/read"
                                            style="display:inline"><button type="submit" class="btn-sm"
                                                title="Mark as read"><i class="fas fa-check"></i></button></form>
                                        <% } %>
                                            <form method="POST" action="/admin/contacts/<%= c.id %>/delete"
                                                style="display:inline"
                                                onsubmit="return confirm('Delete this contact?')"><button type="submit"
                                                    class="btn-sm btn-danger" title="Delete"><i
                                                        class="fas fa-trash"></i></button></form>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
                <% } else { %>
                    <div style="text-align:center;padding:40px;color:#666"><i class="fas fa-inbox"
                            style="font-size:48px;display:block;margin-bottom:15px"></i>
                        <p>No contact submissions yet</p>
                    </div>
                    <% } %>
        </div>
    </div>
</body>

</html>